@{
    ViewData["Title"] = "Trang chủ";
}

<div class="text-center" style="margin-top: 15vh;">
    <h1 class="display-3" style="font-weight: 900; color: #0f172a; letter-spacing: -1.5px;">
        AI Study Planner
    </h1>
    <p class="lead mt-4 text-muted" style="font-size: 1.25rem; max-width: 600px; margin: 0 auto; line-height: 1.8;">
        Hệ thống hỗ trợ học sinh, sinh viên tạo lộ trình học tập cá nhân hóa bằng Trí Tuệ Nhân Tạo.
        Lưu trữ kiến thức, theo dõi tiến độ và kết nối tài liệu học tập thông minh.
    </p>

    <div class="mt-5 d-flex justify-content-center gap-4">
        <a asp-controller="StudyPlans" asp-action="Create" class="btn btn-ai px-4 py-3" style="border-radius: 50px; font-size: 1.1rem; box-shadow: 0 10px 15px -3px rgba(16, 185, 129, 0.3);">
            ✨ Tạo Lộ Trình AI
        </a>

        <a asp-controller="StudyPlans" asp-action="Index" class="btn px-4 py-3 shadow-sm" style="border-radius: 50px; font-size: 1.1rem; background-color: #fff; color: #0f172a; border: 1px solid #e2e8f0; font-weight: 600; transition: all 0.2s;">
            📚 Thư viện của tôi
        </a>
    </div>
</div>