@model IEnumerable<AISmartStudy.Models.StudyPlan>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create" class="btn-ai">+ Tạo Lộ Trình Mới</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Topic)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ContentJson)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CreatedAt)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Topic)
            </td>

            <td>
                    @(item.ContentJson != null && item.ContentJson.Length > 100
                                    ? item.ContentJson.Substring(0, 100) + "..."
                                    : item.ContentJson)
            </td>

            <td>
                @Html.DisplayFor(modelItem => item.CreatedAt)
            </td>
                <td class="text-end">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="action-link text-edit">Sửa</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="action-link text-details">Xem</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="action-link text-delete">Xóa</a>
                </td>
        </tr>
}
    </tbody>
</table>
