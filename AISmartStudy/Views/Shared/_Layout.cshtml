<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AISmartStudy</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AISmartStudy.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="ai-app-container">
        <aside class="ai-sidebar">
            <div class="sidebar-brand">
                <span class="brand-icon">✨</span>
                <span class="brand-text">AI Study Hub</span>
            </div>

            <nav class="sidebar-nav">
                <a class="nav-item" asp-area="" asp-controller="Home" asp-action="Index">
                    🏠 Trang chủ
                </a>
                <a class="nav-item active" asp-area="" asp-controller="StudyPlans" asp-action="Index">
                    📚 Quản lý Lộ trình
                </a>
            </nav>

            <div class="sidebar-history-title">Lịch sử gần đây</div>
            <div class="sidebar-history">
                @await Component.InvokeAsync("SidebarHistory")
            </div>

            <div class="sidebar-footer">
                <div class="user-profile">
                    <div class="avatar">Đ</div>
                    <div class="user-info">
                        <div class="user-name">Hải Đăng</div>
                        <div class="user-role">Học sinh</div>
                    </div>
                </div>
            </div>
        </aside>

        <main class="ai-main-content">
            <div class="content-wrapper">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
